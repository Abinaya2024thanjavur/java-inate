import java.util.*;
public class Main {
    public static void main(String[] args) {
        int[] arr = {1, 2, 3, 4, 5};
        int oddIndexSum = 0;
        int evenIndexSum = 0;
        for (int i = 0; i < arr.length; i++) {

            if (arr[i] % 2 == 0) {
                evenIndexSum += i;
            } else {
                oddIndexSum += i;
            }
        }
        System.out.println(oddIndexSum - evenIndexSum);
    }
}
